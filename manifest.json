{
  "manifest_version": 3,
  "name": "DLsite Thumbnail Preview",
  "version": "1.0.0",
  "description": "DLsiteの作品コード（RJ/BJ/VJ）をホバーするとサムネイルを表示します",
  "permissions": [],
  "host_permissions": [
    "https://www.dlsite.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
